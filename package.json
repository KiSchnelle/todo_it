{
  "name": "todo-it",
  "displayName": "Todo It",
  "description": "Hybrid TODO scanner + checkable task manager: subtasks, multi-file links, due-date reminders, markdown checklists, CodeLens, and an opt-in AI assist (Copilot or any installed Language Model provider). A modern, maintained Todo Tree alternative.",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "KiSchnelle",
  "author": "Kilian Schnelle",
  "repository": {
    "type": "git",
    "url": "https://github.com/KiSchnelle/todo_it.git"
  },
  "bugs": {
    "url": "https://github.com/KiSchnelle/todo_it/issues"
  },
  "homepage": "https://github.com/KiSchnelle/todo_it#readme",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "todo",
    "todo tree",
    "todo tree alternative",
    "todo highlight",
    "todo manager",
    "task manager",
    "task list",
    "tasks",
    "subtasks",
    "checklist",
    "markdown checklist",
    "due dates",
    "reminders",
    "fixme",
    "code annotations",
    "comments",
    "code lens",
    "ai",
    "copilot",
    "language model",
    "chat participant",
    "productivity"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/extension.web.js",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#2563EB",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true,
      "restrictedConfigurations": [
        "todoIt.tags"
      ]
    },
    "virtualWorkspaces": true
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "todoIt",
          "title": "Todo It",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "todoIt": [
        {
          "id": "todoIt.view",
          "name": "Todo It",
          "contextualTitle": "Todo It",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "todoIt.view",
        "when": "workbenchState == empty",
        "contents": "Open a folder or workspace to scan for todos and manage your tasks.\n[Open Folder](command:vscode.openFolder)"
      }
    ],
    "chatParticipants": [
      {
        "id": "todoIt.chat",
        "fullName": "Todo It",
        "name": "todo-it",
        "description": "Ask questions about your TODOs and tasks (@todo-it /summarize, /overdue)",
        "isSticky": true,
        "commands": [
          {
            "name": "summarize",
            "description": "Summarize all scanned TODOs by theme, flag urgent items"
          },
          {
            "name": "overdue",
            "description": "List tasks that are overdue or due today"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "todoIt.refresh",
        "title": "Refresh",
        "category": "Todo It",
        "icon": "$(refresh)"
      },
      {
        "command": "todoIt.addTask",
        "title": "Add Task",
        "category": "Todo It",
        "icon": "$(add)"
      },
      {
        "command": "todoIt.editTask",
        "title": "Edit Task",
        "category": "Todo It",
        "icon": "$(edit)"
      },
      {
        "command": "todoIt.deleteTask",
        "title": "Delete Task",
        "category": "Todo It",
        "icon": "$(trash)"
      },
      {
        "command": "todoIt.toggleTaskDone",
        "title": "Toggle Task Done",
        "category": "Todo It"
      },
      {
        "command": "todoIt.openMatch",
        "title": "Open Todo",
        "category": "Todo It"
      },
      {
        "command": "todoIt.toggleDecorations",
        "title": "Toggle Editor Highlights",
        "category": "Todo It",
        "icon": "$(eye)"
      },
      {
        "command": "todoIt.setGrouping",
        "title": "Change Grouping",
        "category": "Todo It",
        "icon": "$(list-tree)"
      },
      {
        "command": "todoIt.groupByTag",
        "title": "Group Todos by Tag",
        "category": "Todo It"
      },
      {
        "command": "todoIt.groupByFile",
        "title": "Group Todos by File",
        "category": "Todo It"
      },
      {
        "command": "todoIt.groupFlat",
        "title": "Show Todos as Flat List",
        "category": "Todo It"
      },
      {
        "command": "todoIt.setTaskSort",
        "title": "Sort Tasks By…",
        "category": "Todo It",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "todoIt.setFilter",
        "title": "Filter…",
        "category": "Todo It",
        "icon": "$(filter)"
      },
      {
        "command": "todoIt.clearFilter",
        "title": "Clear Filter",
        "category": "Todo It",
        "icon": "$(filter-filled)"
      },
      {
        "command": "todoIt.trackAsTask",
        "title": "Track as Task",
        "category": "Todo It",
        "icon": "$(bookmark)"
      },
      {
        "command": "todoIt.openTaskLink",
        "title": "Open Linked Source",
        "category": "Todo It",
        "icon": "$(go-to-file)"
      },
      {
        "command": "todoIt.addTaskLink",
        "title": "Add Linked Source…",
        "category": "Todo It",
        "icon": "$(link)"
      },
      {
        "command": "todoIt.removeTaskLink",
        "title": "Remove Linked Source…",
        "category": "Todo It",
        "icon": "$(unlink)"
      },
      {
        "command": "todoIt.goToTodo",
        "title": "Go to Todo…",
        "category": "Todo It",
        "icon": "$(search)"
      },
      {
        "command": "todoIt.addSubtask",
        "title": "Add Subtask",
        "category": "Todo It",
        "icon": "$(add)"
      },
      {
        "command": "todoIt.moveTask",
        "title": "Move Task Under…",
        "category": "Todo It",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "todoIt.ai.summarizeTodos",
        "title": "AI: Summarize Found in Code",
        "category": "Todo It",
        "icon": "$(sparkle)"
      },
      {
        "command": "todoIt.ai.suggestPriority",
        "title": "AI: Suggest Priority",
        "category": "Todo It",
        "icon": "$(sparkle)"
      },
      {
        "command": "todoIt.ai.trackAsTask",
        "title": "AI: Track as Task (Expanded)",
        "category": "Todo It",
        "icon": "$(sparkle)"
      },
      {
        "command": "todoIt.ai.explainMatch",
        "title": "AI: Explain Todo",
        "category": "Todo It",
        "icon": "$(sparkle)"
      },
      {
        "command": "todoIt.exportTasks",
        "title": "Export Tasks to Markdown…",
        "category": "Todo It",
        "icon": "$(export)"
      },
      {
        "command": "todoIt.setTaskPriority",
        "title": "Set Priority…",
        "category": "Todo It",
        "icon": "$(arrow-up)"
      },
      {
        "command": "todoIt.snoozeTask",
        "title": "Snooze…",
        "category": "Todo It",
        "icon": "$(clock)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "todoIt.addTask",
          "when": "view == todoIt.view",
          "group": "navigation@1"
        },
        {
          "command": "todoIt.setGrouping",
          "when": "view == todoIt.view",
          "group": "navigation@2"
        },
        {
          "command": "todoIt.toggleDecorations",
          "when": "view == todoIt.view",
          "group": "navigation@3"
        },
        {
          "command": "todoIt.setFilter",
          "when": "view == todoIt.view && !todoIt.hasFilter",
          "group": "navigation@4"
        },
        {
          "command": "todoIt.clearFilter",
          "when": "view == todoIt.view && todoIt.hasFilter",
          "group": "navigation@4"
        },
        {
          "command": "todoIt.refresh",
          "when": "view == todoIt.view",
          "group": "navigation@99"
        },
        {
          "command": "todoIt.ai.summarizeTodos",
          "when": "view == todoIt.view",
          "group": "9_ai@1"
        },
        {
          "command": "todoIt.exportTasks",
          "when": "view == todoIt.view",
          "group": "9_ai@2"
        }
      ],
      "view/item/context": [
        {
          "command": "todoIt.addTask",
          "when": "view == todoIt.view && viewItem == section.tasks",
          "group": "inline@1"
        },
        {
          "command": "todoIt.setTaskSort",
          "when": "view == todoIt.view && viewItem == section.tasks",
          "group": "inline@2"
        },
        {
          "command": "todoIt.editTask",
          "when": "view == todoIt.view && viewItem =~ /\\btask\\b/",
          "group": "inline@1"
        },
        {
          "command": "todoIt.deleteTask",
          "when": "view == todoIt.view && viewItem =~ /\\btask\\b/",
          "group": "inline@2"
        },
        {
          "command": "todoIt.editTask",
          "when": "view == todoIt.view && viewItem =~ /\\btask\\b/",
          "group": "1_modify@1"
        },
        {
          "command": "todoIt.addSubtask",
          "when": "view == todoIt.view && viewItem =~ /\\btask\\b/",
          "group": "1_modify@2"
        },
        {
          "command": "todoIt.moveTask",
          "when": "view == todoIt.view && viewItem =~ /\\btask\\b/",
          "group": "1_modify@3"
        },
        {
          "command": "todoIt.setTaskPriority",
          "when": "view == todoIt.view && viewItem =~ /\\btask\\b/",
          "group": "1_modify@4"
        },
        {
          "command": "todoIt.snoozeTask",
          "when": "view == todoIt.view && viewItem =~ /\\btask\\b/",
          "group": "1_modify@5"
        },
        {
          "command": "todoIt.deleteTask",
          "when": "view == todoIt.view && viewItem =~ /\\btask\\b/",
          "group": "1_modify@6"
        },
        {
          "command": "todoIt.openTaskLink",
          "when": "view == todoIt.view && viewItem =~ /\\blinked\\b/",
          "group": "inline@0"
        },
        {
          "command": "todoIt.openTaskLink",
          "when": "view == todoIt.view && viewItem =~ /\\blinked\\b/",
          "group": "1_modify@0"
        },
        {
          "command": "todoIt.addTaskLink",
          "when": "view == todoIt.view && viewItem =~ /\\btask\\b/",
          "group": "2_links@1"
        },
        {
          "command": "todoIt.removeTaskLink",
          "when": "view == todoIt.view && viewItem =~ /\\blinked\\b/",
          "group": "2_links@2"
        },
        {
          "command": "todoIt.trackAsTask",
          "when": "view == todoIt.view && viewItem =~ /\\bmatch\\b/",
          "group": "inline"
        },
        {
          "command": "todoIt.trackAsTask",
          "when": "view == todoIt.view && viewItem =~ /\\bmatch\\b/",
          "group": "1_modify@1"
        },
        {
          "command": "todoIt.ai.trackAsTask",
          "when": "view == todoIt.view && viewItem =~ /\\bmatch\\b/",
          "group": "1_modify@2"
        },
        {
          "command": "todoIt.ai.explainMatch",
          "when": "view == todoIt.view && viewItem =~ /\\bmatch\\b/",
          "group": "1_modify@3"
        },
        {
          "command": "todoIt.ai.suggestPriority",
          "when": "view == todoIt.view && viewItem =~ /\\btask\\b/",
          "group": "3_ai@1"
        }
      ],
      "commandPalette": [
        {
          "command": "todoIt.editTask",
          "when": "false"
        },
        {
          "command": "todoIt.deleteTask",
          "when": "false"
        },
        {
          "command": "todoIt.toggleTaskDone",
          "when": "false"
        },
        {
          "command": "todoIt.openMatch",
          "when": "false"
        },
        {
          "command": "todoIt.trackAsTask",
          "when": "false"
        },
        {
          "command": "todoIt.openTaskLink",
          "when": "false"
        },
        {
          "command": "todoIt.addTaskLink",
          "when": "false"
        },
        {
          "command": "todoIt.removeTaskLink",
          "when": "false"
        },
        {
          "command": "todoIt.addSubtask",
          "when": "false"
        },
        {
          "command": "todoIt.moveTask",
          "when": "false"
        },
        {
          "command": "todoIt.ai.suggestPriority",
          "when": "false"
        },
        {
          "command": "todoIt.ai.trackAsTask",
          "when": "false"
        },
        {
          "command": "todoIt.ai.explainMatch",
          "when": "false"
        },
        {
          "command": "todoIt.setTaskPriority",
          "when": "false"
        },
        {
          "command": "todoIt.snoozeTask",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Todo It",
      "properties": {
        "todoIt.tags": {
          "type": "array",
          "markdownDescription": "Comment tags to scan for, with optional color, background, and gutter icon overrides.",
          "items": {
            "type": "object",
            "required": [
              "tag"
            ],
            "properties": {
              "tag": {
                "type": "string",
                "description": "The tag text, e.g. TODO."
              },
              "color": {
                "type": "string",
                "description": "Foreground/gutter color (hex or CSS color)."
              },
              "backgroundColor": {
                "type": "string",
                "description": "Optional line background color."
              },
              "iconPath": {
                "type": "string",
                "description": "Optional custom gutter icon path."
              },
              "rulerColor": {
                "type": "string",
                "description": "Optional overview ruler color."
              }
            }
          },
          "default": [
            {
              "tag": "TODO",
              "color": "#ffbd2e"
            },
            {
              "tag": "FIXME",
              "color": "#ff5f56"
            },
            {
              "tag": "HACK",
              "color": "#c678dd"
            },
            {
              "tag": "BUG",
              "color": "#e06c75"
            },
            {
              "tag": "NOTE",
              "color": "#61afef"
            },
            {
              "tag": "XXX",
              "color": "#e5c07b"
            }
          ]
        },
        "todoIt.caseSensitive": {
          "type": "boolean",
          "default": true,
          "description": "Match tags case-sensitively, so only TODO matches (not Todo or todo). Avoids catching everyday words like 'note' or 'hack'."
        },
        "todoIt.commentsOnly": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Only match tags that appear after a comment marker (see `#todoIt.commentMarkers#`). Turn off to match tags anywhere, including prose and strings."
        },
        "todoIt.commentMarkers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "//",
            "#",
            "<!--",
            "/*",
            "*",
            "--",
            ";",
            "%"
          ],
          "markdownDescription": "Comment leaders that mark the start of a comment, used when `#todoIt.commentsOnly#` is enabled. Add or remove markers to suit your languages."
        },
        "todoIt.include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*"
          ],
          "markdownDescription": "Glob patterns of files to scan."
        },
        "todoIt.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/out/**",
            "**/.git/**",
            "**/*.min.*"
          ],
          "markdownDescription": "Glob patterns to exclude from scanning."
        },
        "todoIt.respectGitignore": {
          "type": "boolean",
          "default": true,
          "description": "Skip files ignored by .gitignore."
        },
        "todoIt.maxResults": {
          "type": "number",
          "default": 5000,
          "minimum": 100,
          "description": "Maximum number of scanned matches to collect."
        },
        "todoIt.debounceMs": {
          "type": "number",
          "default": 400,
          "minimum": 0,
          "description": "Delay before re-scanning a file after it changes."
        },
        "todoIt.scan.grouping": {
          "type": "string",
          "enum": [
            "tag",
            "file",
            "flat"
          ],
          "enumDescriptions": [
            "Group by tag",
            "Group by file",
            "Flat list"
          ],
          "default": "tag",
          "description": "How scanned results are grouped in the tree."
        },
        "todoIt.decorations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Highlight tags in the editor with gutter icons and styling."
        },
        "todoIt.codeLens.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Show a clickable CodeLens above each scanned tag in the editor (e.g. 'TODO: refactor · Track as Task'). Off by default — some find it noisy."
        },
        "todoIt.ai.maxFindings": {
          "type": "number",
          "default": 400,
          "minimum": 10,
          "maximum": 5000,
          "markdownDescription": "Maximum number of scanned todos sent to the model by `AI: Summarize Found in Code`. Raise this if your provider has a large context window and you want a more complete summary; lower it to keep the prompt small."
        },
        "todoIt.ai.contextLines": {
          "type": "number",
          "default": 6,
          "minimum": 0,
          "maximum": 50,
          "markdownDescription": "Lines of surrounding source code (±N) sent as context to `AI: Suggest Priority`, `AI: Track as Task (Expanded)`, and `AI: Explain Todo`. Higher = better grounding, but a bigger prompt."
        },
        "todoIt.notifications.dueSoon": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Show a VS Code notification when a task's due date arrives. Off by default — turn on if you want a gentle nudge. Each task is notified at most once per session; the dialog lets you *Open* the view or *Snooze 1 day*."
        },
        "todoIt.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show open task and scanned-todo counts in the status bar. Click the item to focus the Todo It view."
        },
        "todoIt.markdownTasks.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Also surface unchecked Markdown task lines (`- [ ] something`) from `.md`/`.markdown`/`.mdx` files under Found in Code."
        },
        "todoIt.tasks.storage": {
          "type": "string",
          "enum": [
            "file",
            "gitignoredFile",
            "workspaceState"
          ],
          "enumDescriptions": [
            "Committed .vscode/todos.json (shared via git, multi-root friendly)",
            "Gitignored .vscode/todos.local.json (file-based but private to you)",
            "VS Code workspace state (machine-local, never a file)"
          ],
          "default": "file",
          "markdownDescription": "Where manual tasks are stored. `file` is recommended and shareable with your team."
        },
        "todoIt.tasks.sortBy": {
          "type": "string",
          "enum": [
            "manual",
            "priority",
            "dueDate"
          ],
          "enumDescriptions": [
            "Keep the order tasks were added",
            "Highest priority first",
            "Earliest due date first"
          ],
          "default": "manual",
          "description": "How manual tasks are ordered (completed tasks always sink to the bottom)."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint src test",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "node esbuild.js --test",
    "test": "npm run compile && npm run compile-tests && vscode-test",
    "vsix": "vsce package -o todo-it.vsix",
    "vscode:prepublish": "npm run package"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/vscode": "1.120.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "minimatch": "^10.2.5",
    "mocha": "^11.7.6",
    "ovsx": "^1.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
